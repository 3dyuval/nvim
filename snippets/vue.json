{
  "Vue 3 Setup": {
    "prefix": "v3setup",
    "body": [
      "<script setup lang=\"ts\">",
      "$1",
      "</script>",
      "",
      "<template>",
      "  $0",
      "</template>",
      "",
      "<style lang=\"scss\">",
      "</style>"
    ],
    "description": "Vue 3 component with script setup, template, and scss"
  },
  "Define Props": {
    "prefix": "v3props",
    "body": ["defineProps<Props>()", "", "type Props = {", "  $0", "}"],
    "description": "defineProps with Props type"
  },
  "Define Emits": {
    "prefix": "v3emits",
    "body": ["defineEmits<Emits>()", "", "type Emits = {", "  $0", "}"],
    "description": "defineEmits with Emits type"
  },
  "Define Props with const": {
    "prefix": "v3propsr",
    "body": [
      "const props = defineProps<Props>()",
      "",
      "type Props = {",
      "  $0",
      "}"
    ],
    "description": "const props = defineProps with Props type"
  },
  "Define Emits with const": {
    "prefix": "v3emitsr",
    "body": [
      "const emit = defineEmits<Emits>()",
      "",
      "type Emits = {",
      "  $0",
      "}"
    ],
    "description": "const emit = defineEmits with Emits type"
  },
  "Define Slots": {
    "prefix": "v3slots",
    "body": [
      "defineSlots<Slots>()",
      "",
      "type Slots = {",
      "  ${1:default}(props: { ${2:item}: $0 }): any;",
      "}"
    ],
    "description": "defineSlots with Slots type"
  },
  "Define Slots with const": {
    "prefix": "v3slotsr",
    "body": [
      "const slots = defineSlots<Slots>()",
      "",
      "type Slots = {",
      "  ${1:default}(props: { ${2:item}: $0 }): any;",
      "}"
    ],
    "description": "const slots = defineSlots with Slots type"
  },
  "Define Options": {
    "prefix": "v3opts",
    "body": ["defineOptions({", "  $0", "})"],
    "description": "defineOptions"
  },
  "Define Model": {
    "prefix": "v3model",
    "body": ["defineModel<${1:string}>()", "$0"],
    "description": "defineModel with type"
  },
  "Define Model with const": {
    "prefix": "v3modelr",
    "body": ["const ${1:model} = defineModel<${2:string}>()", "$0"],
    "description": "const model = defineModel with type"
  },
  "InstanceType": {
    "prefix": "v3inst",
    "body": ["InstanceType<typeof ${1:Component}>"],
    "description": "Type tool for inheriting types from component"
  }
}
