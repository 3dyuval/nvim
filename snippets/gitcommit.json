{
  "conventional commit: type, subject": {
    "prefix": "cl",
    "body": ["${1}: ${2}"],
    "description": "Conventional commit: type: subject"
  },
  "conventional commit type, subject, scope": {
    "prefix": "cls",
    "body": ["${1}(${2}): ${3}"],
    "description": "Conventional commit: type(scope): subject"
  },
  "conventional commit: type, scope, subject, body": {
    "prefix": "clsb",
    "body": ["${1}(${2}): ${3}", "", "${4}"],
    "description": "Conventional commit: type(scope): subject + body"
  },
  "conventional commit: type, subject, body": {
    "prefix": "clb",
    "body": ["${1}: ${2}", "", "${3}"],
    "description": "Conventional commit: type: subject + body"
  }
}
