
(vim.keymap.set :n :s :i {:desc "Insert after cursor"})
(vim.keymap.set :n :L :I {:desc "Insert at the start of line"})
(vim.keymap.set :n :W :A {:desc "Insert at end of line"})
(vim.keymap.set :n :S :A {:desc "Insert at end of line"})
(vim.keymap.set :n :t "<Del>" {:desc "Delete char under cursor"})
(vim.keymap.set :n :X "<Del>" {:desc "Delete char under cursor"})
